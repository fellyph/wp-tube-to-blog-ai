{
	"name": "wordpress/wp-tube-to-blog-ai",
	"description": "Convert YouTube videos into WordPress blog post drafts using AI.",
	"type": "wordpress-plugin",
	"license": "GPL-2.0-or-later",
	"require": {
		"php": ">=8.1",
		"wordpress/wp-ai-client": "^0.4"
	},
	"autoload": {
		"classmap": [
			"includes/"
		]
	},
	"config": {
		"allow-plugins": {
			"composer/installers": true,
			"php-http/discovery": true
		}
	}
}
