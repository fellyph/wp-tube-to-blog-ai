{
	"name": "creatorstack-ai",
	"version": "1.0.0",
	"description": "AI toolkit for creator workflows in WordPress.",
	"author": {
		"name": "Fellyph Cintra",
		"url": "https://github.com/fellyph"
	},
	"private": true,
	"files": [
		"README.md",
		"creatorstack-ai.php",
		"wp-tube-to-blog-ai.php",
		"uninstall.php",
		"build",
		"includes",
		"languages"
	],
	"scripts": {
		"build": "wp-scripts build",
		"start": "wp-scripts start",
		"lint:js": "wp-scripts lint-js",
		"lint:css": "wp-scripts lint-style",
		"test": "npm run test:node && npm run test:e2e",
		"test:node": "node --test tests/node/*.test.mjs",
		"version:set": "node scripts/sync-version.mjs",
		"packages-update": "wp-scripts packages-update",
		"plugin-zip": "wp-scripts plugin-zip",
		"test:e2e": "npm run build && playwright test",
		"test:e2e:ui": "npm run build && playwright test --ui",
		"test:e2e:debug": "npm run build && playwright test --debug",
		"playground:start": "npm run build && wp-playground-cli server --php=8.3 --wp=nightly --mount=.:/wordpress/wp-content/plugins/creatorstack-ai --blueprint=playground/blueprint.json --login",
		"playground:debug": "npm run build && wp-playground-cli server --php=8.3 --wp=nightly --mount=.:/wordpress/wp-content/plugins/creatorstack-ai --blueprint=playground/blueprint.json --login --xdebug",
		"playground:check": "npm run build && wp-playground-cli run-blueprint --php=8.3 --wp=nightly --mount=.:/wordpress/wp-content/plugins/creatorstack-ai --blueprint=playground/blueprint.json --login",
		"playground:url": "node scripts/playground-url.mjs",
		"playground:url:source": "node scripts/playground-url.mjs playground/blueprint-github-source.json"
	},
	"devDependencies": {
		"@playwright/test": "^1.59.0",
		"@wordpress/scripts": "^30.0.0",
		"@wp-playground/cli": "^3.1.0"
	}
}
